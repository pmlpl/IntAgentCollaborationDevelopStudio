Screen {
    background: #1e1e2e;
    color: #cdd6f4;
}

Header {
    background: #313244;
    color: #89b4fa;
    text-style: bold;
}

Footer {
    background: #313244;
    color: #a6adc8;
}

.panel-box {
    border: round #45475a;
    padding: 1 2;
    margin: 1;
    background: #181825;
}

.title-text {
    text-style: bold;
    color: #89dceb;
    text-align: center;
    padding: 1;
}

.accent {
    color: #a6e3a1;
}

.toolbar {
    height: auto;
    min-height: 3;
    padding: 0 1 1 1;
    align: center middle;
}

.toolbar Button {
    margin: 0 1;
    min-width: 14;
    height: 3;
    background: #45475a;
    color: #cdd6f4;
    border: none;
    content-align: center middle;
}

.toolbar Button:hover {
    background: #585b70;
}

.toolbar Button.-primary {
    background: #89b4fa;
    color: #11111b;
    text-style: bold;
}

.toolbar Button.-primary:hover {
    background: #b4befe;
}

#agent-container {
    height: 1fr;
    padding: 0 1;
}

#agent-box {
    height: 1fr;
}

#agent-list {
    height: 1fr;
    min-height: 8;
    max-height: 14;
    border: round #45475a;
    margin: 1 0;
    background: #181825;
}

#agent-detail-scroll {
    height: 1fr;
    min-height: 6;
    max-height: 16;
    margin: 0 0 1 0;
    padding: 0 1;
}

#agent-detail {
    width: 100%;
    height: auto;
    padding: 1 1;
}

#project-list {
    height: 1fr;
    min-height: 8;
    border: round #45475a;
    margin: 1 0;
    background: #181825;
}

#onboard-container {
    height: 1fr;
    padding: 0 1;
}

#preview-scroll {
    height: 1fr;
    min-height: 6;
    max-height: 14;
    margin: 1 0;
}

#research-scroll {
    height: auto;
    max-height: 12;
    min-height: 4;
    margin: 0 0 1 0;
}

#research-next-hint {
    margin: 0 1 1 1;
    text-align: center;
}

#step-1 Horizontal {
    height: auto;
    margin: 0 1 1 1;
    align: center middle;
}

#step-1 Horizontal Button {
    margin: 0 1;
}

#orch-container {
    height: auto;
    max-height: 14;
    margin: 0 1 0 1;
}

#orch-progress {
    margin: 0 1 1 1;
}

#dispatch-container {
    width: 72;
    max-width: 90%;
    height: auto;
    max-height: 90%;
    margin: 1 2;
}

#dispatch-answer-input {
    height: 8;
    min-height: 4;
    margin: 0 1 1 1;
    border: round #45475a;
    background: #11111b;
}

#dispatch-overview-scroll,
#dispatch-proposal-scroll {
    height: auto;
    max-height: 12;
    min-height: 4;
    margin: 0 1 1 1;
}

#brief-answer-input {
    height: 8;
    min-height: 4;
    margin: 0 1 1 1;
    border: round #45475a;
    background: #11111b;
}

#brief-overview-scroll,
#brief-proposal-scroll {
    height: auto;
    max-height: 14;
    min-height: 4;
    margin: 0 1 1 1;
}

#brief-container {
    height: 1fr;
    padding: 0 1;
}
