/* ═══════════════════════════════════════════════════════════════════════════
   IntAgent Studio — 工业深蓝 + 琥珀金 配色
   设计语言：控制台/指挥舱，高对比度，精确色彩语义
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── 全局底色 ── */
Screen {
    background: #0d1117;
    color: #c9d1d9;
}

/* ── 顶栏 / 底栏 ── */
Header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
}

Footer {
    background: #161b22;
    color: #8b949e;
}

/* ── 通用面板 ── */
.panel-box {
    border: solid #30363d;
    padding: 1 2;
    margin: 1;
    background: #0f1729;
}

/* ── 全屏页统一骨架 ── */
.page-shell {
    height: 1fr;
    padding: 0 1;
}

.page-body {
    height: 1fr;
    min-height: 0;
    overflow-y: auto;
}

.page-scroll {
    height: 1fr;
    min-height: 8;
    margin: 1 0;
}

.page-hint {
    height: 1;
    width: 100%;
    text-align: center;
    margin: 0 0 1 0;
}

.page-actions {
    height: auto;
    width: 100%;
    align: center middle;
    margin: 0 0 1 0;
}

.page-actions Button {
    margin: 0 1;
    min-width: 16;
    height: 3;
}

.page-step {
    height: 1fr;
    min-height: 0;
}

/* ── 容器 id ── */
#hub-container,
#agent-container,
#onboard-container,
#expand-container,
#welcome-container,
#review-box {
    height: 1fr;
    padding: 0 1;
}

#review-box {
    height: 1fr;
}

#onboard-container,
#expand-container {
    layout: vertical;
}

#onboard-container .page-body,
#expand-container .page-body {
    height: 1fr;
    min-height: 0;
    overflow-y: auto;
}

#dispatch-goal-input,
#dispatch-notes-input {
    margin: 0 0 1 0;
}

#dispatch-step-goal,
#dispatch-step-approve {
    height: 1fr;
    min-height: 0;
}

/* ── 文本语义类 ── */
.title-text {
    text-style: bold;
    color: #58a6ff;
    text-align: center;
    padding: 1;
}

.accent {
    color: #3fb950;
}

.muted {
    color: #6e7681;
}

/* ── 状态色变量说明（Rich markup 内联使用） ──
   [green]   = 成功/启用/已安装
   [yellow]  = 警告/可更新/需配置
   [red]     = 错误/禁用/失败
   [cyan]    = BYOK / 第三方 API
   [magenta] = 编排进度
   [blue]    = 链接/高亮
   [dim]     = 次要信息
   [bold]    = 强调
   [italic]  = 提示文本
   [reverse] = 选中行
*/

/* ── 按钮 ── */
.toolbar {
    height: auto;
    min-height: 3;
    padding: 0 1 1 1;
    align: center middle;
}

.toolbar Button {
    margin: 0 1;
    min-width: 14;
    height: 3;
    background: #21262d;
    color: #c9d1d9;
    border: solid #30363d;
    content-align: center middle;
}

.toolbar Button:hover {
    background: #30363d;
    border: solid #58a6ff;
}

.toolbar Button.-primary {
    background: #1f6feb;
    color: #ffffff;
    text-style: bold;
    border: solid #388bfd;
}

.toolbar Button.-primary:hover {
    background: #388bfd;
}

/* ── Dashboard 指挥舱 ── */

/* 顶部状态栏 */
#dash-status-bar {
    height: 3;
    padding: 0 2;
    margin: 0 1 1 1;
    border: solid #30363d;
    background: #161b22;
}

#dash-status-bar Static {
    color: #8b949e;
}

/* 主面板区：org + task 并排 */
#main-panels {
    height: 1fr;
    min-height: 0;
    margin: 0 1;
}

#main-panels > Static {
    height: 1fr;
    min-height: 0;
    border: solid #30363d;
}

#org-panel {
    width: 30;
    margin-right: 1;
    padding: 1;
    background: #0f1729;
}

#task-panel {
    width: 1fr;
    padding: 1;
    background: #0f1729;
}

/* 底部栏：编排进度 + 通信中枢 */
#bottom-bar {
    height: auto;
    max-height: 12;
    margin: 0 1;
    border: solid #30363d;
    padding: 0 1;
    background: #0f1729;
    overflow-y: auto;
}

#orch-panel-text {
    height: auto;
    max-height: 8;
}

#orch-progress {
    margin: 0 0 0 0;
}

#agent-activity {
    height: auto;
    margin: 0;
    padding: 0;
    color: #8b949e;
}

#message-log {
    height: auto;
    max-height: 5;
    min-height: 1;
    margin: 0;
    overflow-y: auto;
    background: #0d1117;
    border: solid #30363d;
    padding: 0 1;
}

#ceo-chat-input {
    width: 1fr;
    margin: 0;
    max-height: 3;
}

/* ── Agent 目录 ── */
#agent-box {
    height: 1fr;
}

/* 上下布局：上方选择列表（全宽限高），下方详情面板 */
#agent-list {
    width: 100%;
    height: auto;
    max-height: 10;
    min-height: 4;
    margin-bottom: 1;
    border: solid #30363d;
    background: #0f1729;
}

#agent-list:focus {
    border: solid #58a6ff;
}

/* 类别分组标题（ListView 中的 Static 行） */
.agent-category-header {
    color: #d29922;
    text-style: bold;
    padding: 0 1;
    background: #161b22;
    border-top: solid #30363d;
    border-bottom: solid #30363d;
}

/* 详情面板：全宽，占剩余高度 */
#agent-detail {
    width: 100%;
    height: 1fr;
    min-height: 5;
    padding: 1 1;
    border: solid #30363d;
    background: #0f1729;
    overflow-y: auto;
}

/* Agent 状态小条：10 格紧凑 */
.agent-bar {
    color: #3fb950;
}
.agent-bar-warn {
    color: #d29922;
}
.agent-bar-dim {
    color: #21262d;
}

/* ── 项目中心 ── */
#project-list {
    height: 1fr;
    min-height: 8;
    border: solid #30363d;
    background: #0f1729;
}

#project-list:focus {
    border: solid #58a6ff;
}

/* ── 调研 & 简报 ── */
#preview-scroll {
    height: 1fr;
    min-height: 6;
    max-height: 14;
    margin: 1 0;
}

#research-scroll {
    height: auto;
    max-height: 12;
    min-height: 4;
    margin: 0 0 1 0;
}

#brief-answer-input {
    height: 8;
    min-height: 4;
    margin: 0 1 1 1;
    border: solid #30363d;
    background: #0d1117;
}

#brief-overview-scroll,
#brief-proposal-scroll {
    height: auto;
    max-height: 14;
    min-height: 4;
    margin: 0 1 1 1;
}

#brief-container {
    height: 1fr;
    padding: 0 1;
}

/* ── 审批 & 扩建 ── */
#review-list {
    height: 1fr;
    min-height: 6;
    border: solid #30363d;
    margin: 1 0;
    background: #0f1729;
}

#review-list:focus {
    border: solid #58a6ff;
}

#review-checklist {
    height: auto;
    max-height: 10;
    min-height: 2;
}

#expand-container .Select {
    margin: 1 0;
}

#expand-container Input {
    margin: 0 0 1 0;
}

/* ── 通用 ListView 高亮行 ── */
ListView {
    background: #0f1729;
}

ListView:focus > ListView > ListItem.--highlight {
    background: #1f6feb 30%;
}

/* ── ProgressBar ── */
ProgressBar {
    height: 1;
    border: solid #30363d;
}

ProgressBar > .bar--complete {
    background: #3fb950;
}

ProgressBar > .bar--indeterminate {
    background: #d29922;
}

/* ── Input ── */
Input {
    border: solid #30363d;
    background: #0d1117;
}

Input:focus {
    border: solid #58a6ff;
}

/* ── Select ── */
Select {
    border: solid #30363d;
    background: #0f1729;
}

Select:focus {
    border: solid #58a6ff;
}

/* ── Checkbox ── */
Checkbox {
    background: #0f1729;
}

/* ── LoadingIndicator ── */
LoadingIndicator {
    color: #d29922;
}

/* ── Notification / Toast ── */
Notification {
    background: #161b22;
    border: solid #30363d;
}

/* ── ChatScreen ── */

#ChatScreen {
    layout: vertical;
}

#chat-header {
    height: 3;
    background: #161b22;
    border: solid #30363d;
    padding: 0 1;
    content-align: left middle;
    color: #8b949e;
}

#chat-messages {
    height: 1fr;
    border: solid #30363d;
    background: #0d1117;
    scrollbar-color: #30363d;
    scrollbar-color-hover: #484f58;
    padding: 0 1;
}

#chat-status {
    height: 1;
    background: #161b22;
    color: #8b949e;
    padding: 0 1;
}

#chat-input {
    width: 1fr;
    max-height: 3;
    border: solid #30363d;
    background: #161b22;
}

#chat-input:focus {
    border: solid #58a6ff;
}
